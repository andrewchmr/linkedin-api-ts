{
  "name": "linkedin-api-ts",
  "version": "0.1.0",
  "description": "Node.js/TypeScript client for fetching data from LinkedIn for free",
  "keywords": [
    "linkedin",
    "linkedin-api",
    "linkedin-scraper",
    "scraper",
    "voyager",
    "profile",
    "search",
    "typescript",
    "nodejs"
  ],
  "author": "Andrew Chemerynskiy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewchmr/linkedin-api-ts.git"
  },
  "bugs": {
    "url": "https://github.com/andrewchmr/linkedin-api-ts/issues"
  },
  "homepage": "https://github.com/andrewchmr/linkedin-api-ts#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build-fast": "tsup src/index.ts --format cjs,esm",
    "build": "tsup src/index.ts --format cjs,esm && dts-bundle-generator -o dist/index.d.ts src/index.ts",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "dts-bundle-generator": "^9.5.1",
    "prettier": "3.8.1",
    "tsup": "8.5.1",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.3"
  },
  "packageManager": "pnpm@9.11.0",
  "dependencies": {
    "impit": "^0.13.0"
  }
}
